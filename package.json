{
  "name": "@wlearn/bo",
  "version": "0.1.0",
  "description": "Bayesian optimization with Gaussian processes for hyperparameter tuning",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "wasm/",
    "dist/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node test/test.js",
    "bench": "node bench/bench.js",
    "build": "bash scripts/build-wasm.sh",
    "build:browser": "bash scripts/build-browser.sh",
    "verify": "bash scripts/verify-exports.sh",
    "prepack": "node scripts/prepack.js",
    "prepublishOnly": "node scripts/prepublish.js"
  },
  "dependencies": {
    "@wlearn/core": "0.2.0",
    "@wlearn/automl": "0.2.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  },
  "keywords": [
    "bayesian-optimization",
    "gaussian-process",
    "hyperparameter-tuning",
    "automl",
    "wasm",
    "webassembly",
    "wlearn"
  ],
  "author": "Anton Zemlyansky",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/bo.git"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wlearn-org/bo/issues"
  },
  "homepage": "https://wlearn.org"
}
